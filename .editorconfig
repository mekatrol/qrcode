# ==============================================================================
# Root EditorConfig
# ==============================================================================
# This file is the root EditorConfig for the repository.
# EditorConfig lookup stops here, which prevents parent folders from silently
# contributing additional formatting or analyzer settings.
root = true

# ==============================================================================
# C# source files
# ==============================================================================
[*.cs]

# ==============================================================================
# Core file formatting
# ==============================================================================
# Use spaces only, with a standard four-space indentation width.
indent_style = space
indent_size = 4
tab_width = 4

# Use Windows-style CRLF line endings and ensure every file ends with a final
# newline so diffs and tooling stay consistent.
end_of_line = crlf
insert_final_newline = true

# ==============================================================================
# Using directives and file header behavior
# ==============================================================================
# Keep using directives in one logical block rather than splitting them into
# multiple groups.
dotnet_separate_import_directive_groups = false

# Do not force System namespaces to sort before all others. This keeps the
# using order simple and neutral rather than framework-prioritized.
dotnet_sort_system_directives_first = false

# Do not require a standardized file header banner.
file_header_template = unset

# Place using directives outside the namespace declaration. This is compatible
# with file-scoped namespaces and keeps the file layout consistent.
csharp_using_directive_placement = outside_namespace:error

# ==============================================================================
# Member qualification preferences
# ==============================================================================
# Prefer unqualified member access over explicit 'this.' unless qualification is
# genuinely required for correctness or disambiguation.
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_event = false:silent

# ==============================================================================
# Built-in type keyword preferences
# ==============================================================================
# Prefer C# language keywords such as 'string', 'int', and 'bool' over CLR type
# names such as 'String', 'Int32', and 'Boolean'.
dotnet_style_predefined_type_for_locals_parameters_members = true:silent
dotnet_style_predefined_type_for_member_access = true:silent

# ==============================================================================
# Parentheses preferences
# ==============================================================================
# Prefer clarity-preserving parentheses in arithmetic, relational, and other
# binary expressions, but avoid unnecessary parentheses elsewhere.
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:silent
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:silent
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:silent
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:silent

# ==============================================================================
# General .NET style preferences
# ==============================================================================
# Require explicit accessibility modifiers on non-interface members so the
# public surface area is always intentional and obvious.
dotnet_style_require_accessibility_modifiers = for_non_interface_members:silent

# Prefer the more concise and idiomatic language forms below when they preserve
# readability and intent.
dotnet_style_coalesce_expression = true:error
dotnet_style_null_propagation = true:suggestion
dotnet_style_object_initializer = true:error
dotnet_style_collection_initializer = true:error
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_simplified_boolean_expressions = true:error
dotnet_style_prefer_simplified_interpolation = true:suggestion

# Prefer inferred names when tuple and anonymous member names can be expressed
# more simply without losing clarity.
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion

# Prefer conditional expressions when they improve readability and avoid
# unnecessary temporary variables or repetitive branching.
dotnet_style_prefer_conditional_expression_over_assignment = true:silent
dotnet_style_prefer_conditional_expression_over_return = true:silent

# Prefer auto-properties and readonly fields where the extra ceremony of manual
# backing storage is unnecessary.
dotnet_style_prefer_auto_properties = true:silent
dotnet_style_readonly_field = true:suggestion

# Prefer direct and idiomatic null checking.
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion

# Keep wrapped operators at the beginning of the continuation line.
dotnet_style_operator_placement_when_wrapping = beginning_of_line

# Encourage the namespace to reflect the folder structure.
dotnet_style_namespace_match_folder = true:suggestion

# Treat unused parameters as a code-quality issue across the board.
dotnet_code_quality_unused_parameters = all:error

# Keep accessibility-bearing partial methods build-blocking if no implementation
# is produced, including source-generated implementations.
dotnet_diagnostic.CS8795.severity = error
dotnet_diagnostic.IDE0290.severity = error

# Prefer collection expressions where Roslyn can apply them safely and naturally.
dotnet_style_prefer_collection_expression = when_types_loosely_match:suggestion

# ==============================================================================
# var preferences
# ==============================================================================
# Prefer implicit typing consistently, including built-in types, obvious types,
# and all other local declarations.
csharp_style_var_for_built_in_types = true:error
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_elsewhere = true:error

# ==============================================================================
# Expression-bodied members
# ==============================================================================
# Allow expression-bodied members where they are typically compact and readable,
# but avoid forcing them for members that often become harder to scan when
# compressed to a single expression.
csharp_style_expression_bodied_accessors = true:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_lambdas = true:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_local_functions = false:silent
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_operators = false:silent

# ==============================================================================
# Pattern matching and related expression preferences
# ==============================================================================
# Prefer modern pattern matching forms where they simplify casting, null checks,
# and property inspection.
csharp_style_pattern_matching_over_as_with_null_check = true:error
csharp_style_pattern_matching_over_is_with_cast_check = true:error
csharp_style_prefer_pattern_matching = true:silent
csharp_style_prefer_not_pattern = true:error
csharp_style_prefer_extended_property_pattern = true:suggestion
csharp_style_prefer_switch_expression = false:suggestion

# Prefer concise delegate invocation and modern null/type test forms.
csharp_style_conditional_delegate_call = true:error
csharp_style_prefer_null_check_over_type_check = true:suggestion

# ==============================================================================
# Modern C# language preferences
# ==============================================================================
# Prefer simpler and more modern language constructs when they are a net win
# for readability and maintainability.
csharp_prefer_static_local_function = true:suggestion
csharp_prefer_static_anonymous_function = true:suggestion
csharp_style_prefer_readonly_struct = true:suggestion
csharp_style_prefer_readonly_struct_member = true:suggestion
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_prefer_unbound_generic_type_in_nameof = true:suggestion

# Prefer concise expression-level modernizations.
csharp_prefer_simple_default_expression = true:suggestion
csharp_style_deconstructed_variable_declaration = true:suggestion
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion
csharp_style_inlined_variable_declaration = true:error
csharp_style_prefer_index_operator = true:suggestion
csharp_style_prefer_local_over_anonymous_function = true:suggestion
csharp_style_prefer_range_operator = true:suggestion
csharp_style_prefer_tuple_swap = true:suggestion
csharp_style_prefer_utf8_string_literals = true:suggestion
csharp_style_throw_expression = true:error

# When a value is intentionally ignored, prefer assigning to the discard rather
# than leaving an apparently-unused value expression or assignment.
csharp_style_unused_value_assignment_preference = discard_variable:silent
csharp_style_unused_value_expression_statement_preference = discard_variable:silent

# ==============================================================================
# Code block and namespace preferences
# ==============================================================================
# Always require braces, even for single-line blocks.
csharp_prefer_braces = true:error

# Prefer the simplified using statement form when disposal scope is obvious.
csharp_prefer_simple_using_statement = true:error

# Enforce file-scoped namespaces consistently.
csharp_style_namespace_declarations = file_scoped:error

# Do not prefer top-level statements for normal project code.
csharp_style_prefer_top_level_statements = false:error

# Prefer method-group conversion where it remains clear.
csharp_style_prefer_method_group_conversion = true:silent

# Keep modifier order consistent and predictable.
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async

# ==============================================================================
# C# formatting
# ==============================================================================
# New-line preferences.
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_open_brace = all
csharp_new_line_between_query_expression_clauses = true

# Indentation preferences.
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = true
csharp_indent_labels = one_less_than_current
csharp_indent_switch_labels = true

# Spacing preferences.
csharp_space_after_cast = false
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_after_comma = true
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_after_semicolon_in_for_statement = true
csharp_space_around_binary_operators = before_and_after
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_before_comma = false
csharp_space_before_open_square_brackets = false
csharp_space_before_semicolon_in_for_statement = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_between_square_brackets = false

# Preserve intentionally compact one-line constructs rather than aggressively
# expanding them during formatting.
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = true

# ==============================================================================
# Naming rules
# ==============================================================================
# Interfaces should begin with the conventional 'I' prefix.
dotnet_naming_rule.interfaces_should_begin_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_should_begin_with_i.style = interface_prefix_i
dotnet_naming_rule.interfaces_should_begin_with_i.severity = suggestion

# Types should use PascalCase.
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case
dotnet_naming_rule.types_should_be_pascal_case.severity = suggestion

# Methods, properties, and events should use PascalCase.
dotnet_naming_rule.non_field_members_should_be_pascal_case.symbols = non_field_members
dotnet_naming_rule.non_field_members_should_be_pascal_case.style = pascal_case
dotnet_naming_rule.non_field_members_should_be_pascal_case.severity = suggestion

# Private and private_protected fields should use _camelCase.
dotnet_naming_rule.private_fields_should_be_underscore_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_underscore_camel_case.style = underscore_camel_case
dotnet_naming_rule.private_fields_should_be_underscore_camel_case.severity = error

# Symbol groups.
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum
dotnet_naming_symbols.types.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_symbols.non_field_members.applicable_kinds = method, property, event
dotnet_naming_symbols.non_field_members.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, private_protected

# Naming styles.
dotnet_naming_style.interface_prefix_i.required_prefix = I
dotnet_naming_style.interface_prefix_i.capitalization = pascal_case

dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

# ==============================================================================
# Diagnostic severities
# ==============================================================================
# IDE0055 is the formatting rule umbrella. Setting this to warning makes
# formatting drift visible without making it as disruptive as an error.
dotnet_diagnostic.IDE0055.severity = warning

# IDE rule severities for the style choices explicitly enforced above.
dotnet_diagnostic.IDE0004.severity = error   # Remove unnecessary cast
dotnet_diagnostic.IDE0005.severity = error   # Using directive is unnecessary
dotnet_diagnostic.IDE0011.severity = error   # Add braces
dotnet_diagnostic.IDE0017.severity = error   # Simplify object initialization
dotnet_diagnostic.IDE0028.severity = error   # Simplify collection initialization
dotnet_diagnostic.IDE0051.severity = error   # Remove unused private member
dotnet_diagnostic.IDE0052.severity = error   # Remove unread private member
dotnet_diagnostic.IDE0059.severity = error   # Remove unnecessary value assignment
dotnet_diagnostic.IDE0060.severity = error   # Remove unused parameter
dotnet_diagnostic.IDE0079.severity = none    # Remove unnecessary suppression
dotnet_diagnostic.IDE1006.severity = error   # Naming rule violation

# Collection expression diagnostics. These rule IDs are part of the current
# language-rules set and are safe to configure directly.
dotnet_diagnostic.IDE0300.severity = error   # Use collection expression for array
dotnet_diagnostic.IDE0301.severity = error   # Use collection expression for empty
dotnet_diagnostic.IDE0305.severity = none    # Use collection expression for fluent

# Compiler nullable diagnostics.
dotnet_diagnostic.CS8601.severity = error    # Possible null reference assignment
dotnet_diagnostic.CS8618.severity = none     # Non-nullable member not initialized
dotnet_diagnostic.CS8795.severity = error    # Partial method must have an implementation (i.e. [LoggerMessage] source generator did not run)

# XML documentation warning.
dotnet_diagnostic.CS1591.severity = none     # Missing XML comment for publicly visible type or member

# Library / analyzer rules you explicitly chose to control.
dotnet_diagnostic.SYSLIB1045.severity = none # Use GeneratedRegexAttribute
dotnet_diagnostic.CA1304.severity = error    # Specify CultureInfo
dotnet_diagnostic.CA1822.severity = error    # Mark members as static
dotnet_diagnostic.CA1827.severity = error    # Do not use Count/LongCount when Any can be used
dotnet_diagnostic.CA1854.severity = error    # Prefer IDictionary.TryGetValue
dotnet_diagnostic.CA1859.severity = none     # Use concrete types when possible for performance
dotnet_diagnostic.CA1860.severity = error    # Avoid Enumerable.Any when Length/Count/property is available
dotnet_diagnostic.CA1873.severity = error    # Avoid unnecessary evaluation when logging is disabled